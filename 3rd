/* ---------- Date helpers ---------- */
function dateToKey(d) {
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}-${String(d.getDate()).padStart(2,"0")}`;
}
function todayKey(){ return dateToKey(new Date()); }
function keyToDate(key){ const [y,m,d]=key.split("-").map(Number); return new Date(y,m-1,d); }
function formatDateLabel(key){
  const d = keyToDate(key);
  const days = ["일","월","화","수","목","금","토"];
  return `${d.getMonth()+1}월 ${d.getDate()}일 (${days[d.getDay()]})`;
}
function shiftDateKey(key, delta){ const d = keyToDate(key); d.setDate(d.getDate()+delta); return dateToKey(d); }
function sortByName(arr){ return [...arr].sort((a,b) => a.name.localeCompare(b.name, "ko")); }

const WEEKDAYS = ["월","화","수","목","금","토","일"];
function getWeekdayKorean(key){
  const d = keyToDate(key);
  const map = ["일","월","화","수","목","금","토"];
  return map[d.getDay()];
}
function isScheduledDay(resident, dateKey){
  if (!resident.schedule || resident.schedule.length === 0) return true;
  return resident.schedule.includes(getWeekdayKorean(dateKey));
}
const SCHEDULE_OVERRIDES = {
  "김태영": ["수","목","금"],
  "정숙자": ["월","화","목"],
  "강귀화": ["화","수","목"],
  "강정자": ["월","수","금"],
  "임춘자1": ["월","수","금"],
  "김상순": ["화","목","토"],
  "이숙조": ["화","목","토"],
};
function applyScheduleOverrides(residents){
  return residents.map(r =>
    (r.schedule === undefined && SCHEDULE_OVERRIDES[r.name])
      ? { ...r, schedule: SCHEDULE_OVERRIDES[r.name] }
      : r
  ).map(r => r.name === "임춘자2" ? { ...r, schedule: [] } : r);
}

function migrateVehicleNames(residents){
  return residents.map(r =>
    OLD_VEHICLE_MAP[r.vehicle] ? { ...r, vehicle: OLD_VEHICLE_MAP[r.vehicle] } : r
  );
}

