  } catch(e) {}
  try {
    const m = lsGet("meals");
    if (m) S.meals = JSON.parse(m);
  } catch(e) {}
  S.loaded = true;
  debouncedPersist("residents", S.residents);
  render();
}

function saveResidents(){ debouncedPersist("residents", S.residents); }
function saveAttendance(){ debouncedPersist("attendance", S.attendance); }
function saveMeals(){ debouncedPersist("meals", S.meals); }

/* ---------- Actions ---------- */
function setTab(tab){ S.tab = tab; if (tab !== "slides") S.page = 0; render(); }
function setSelectedDate(key){ S.selectedDate = key; render(); }
function shiftDate(delta){ S.selectedDate = shiftDateKey(S.selectedDate, delta); render(); }
function goToday(){ S.selectedDate = todayKey(); render(); }

function setStatus(id, status){
  const day = { ...(S.attendance[S.selectedDate] || {}) };
  day[id] = day[id] === status ? undefined : status;
  S.attendance = { ...S.attendance, [S.selectedDate]: day };
  saveAttendance();
  render();
}
function setMealCount(floor, count){
  const day = { ...(S.meals[S.selectedDate] || {}) };
  day[floor] = count;
  S.meals = { ...S.meals, [S.selectedDate]: day };
  saveMeals();
  render();
}
function setVehicle(id, vehicle){
  S.residents = S.residents.map(r => r.id === id ? { ...r, vehicle } : r);
  saveResidents();
  render();
}
function removeResident(id){
  S.residents = S.residents.filter(r => r.id !== id);
  saveResidents();
  render();
}
function toggleScheduleDay(id, day){
  S.residents = S.residents.map(r => {
    if (r.id !== id) return r;
    const current = r.schedule || [];
    const next = current.includes(day) ? current.filter(d => d !== day) : [...current, day];
    return { ...r, schedule: next };
  });
  saveResidents();
  render();
}
function clearSchedule(id){
  S.residents = S.residents.map(r => r.id === id ? { ...r, schedule: [] } : r);
  saveResidents();
  render();
}
function toggleAddForm(){ S.showAdd = !S.showAdd; render(); }
function updateNewName(v){ S.newName = v; }
function updateNewFloor(v){ S.newFloor = v; }
function updateNewVehicle(v){ S.newVehicle = v; }
function addResident(){
  const nameInput = document.getElementById("newNameInput");
  const name = nameInput ? nameInput.value.trim() : "";
  if (!name) return;
  const id = "r_" + Date.now();
  S.residents = [...S.residents, { id, name, floor: S.newFloor, vehicle: S.newVehicle, schedule: [] }];
  S.newName = "";
  S.showAdd = false;
  saveResidents();
  render();
}
function gotoPage(i){ S.page = Math.max(0, Math.min(2, i)); render(); }

function computeCounts(){
  const counts = { present: 0, absent: 0, expected: 0 };
  const today = S.attendance[S.selectedDate] || {};
  S.residents.forEach(r => { const s = today[r.id]; if (s) counts[s]++; });
  return counts;
}

function downloadBlob(blob, filename){
  // iOS 홈화면 앱 모드에서는 공유 시트를 통해 저장 (파일 앱, 메일 등으로 보낼 수 있음)
  try {
    if (navigator.canShare && window.File) {
      const file = new File([blob], filename, { type: blob.type });
      if (navigator.canShare({ files: [file] })) {
        navigator.share({ files: [file], title: filename }).catch(() => fallbackDownload(blob, filename));
        return;
      }
    }
  } catch (e) { /* 무시하고 아래 방식으로 */ }
  fallbackDownload(blob, filename);
}

function fallbackDownload(blob, filename){
  const url = URL.createObjectURL(blob);
  // 새 탭으로 열기 (iOS Safari에서 다운로드 대신 표시되면 사용자가 공유버튼으로 저장 가능)
  const a = document.createElement("a");
  a.href = url;
  a.download = filename;
  a.target = "_blank";
  a.rel = "noopener";
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(() => {
    // 클릭이 안 먹은 경우 대비: 새 창으로 직접 열기
    try { window.open(url, "_blank"); } catch(e) {}
    setTimeout(() => URL.revokeObjectURL(url), 4000);
  }, 300);
}

function exportAsCSV(dateKey, dateLabel, todayAttendance, todayMeals, counts, absentNames, expectedNames){
  const rows = [];
  rows.push(["서구케어재가노인주간보호센터"]);
  rows.push(["날짜", dateLabel]);
  rows.push([]);
  rows.push(["구분", "인원수"]);
  rows.push(["전체 인원", S.residents.length]);
  rows.push(["출석", counts.present]);
  rows.push(["결석", counts.absent]);
  rows.push(["등원예정", counts.expected]);
  rows.push([]);
  FLOORS.forEach(f => rows.push([f + " 조식", todayMeals[f] || 0]));
  rows.push([]);
  rows.push(["결석자", absentNames.length ? absentNames.join(", ") : "없음"]);
  rows.push(["등원예정자", expectedNames.length ? expectedNames.join(", ") : "없음"]);
  rows.push([]);
  rows.push(["이름", "층", "상태", "하원차량"]);
  S.residents.forEach(r => {
    rows.push([
      r.name,
      r.floor,
      todayAttendance[r.id] ? STATUS[todayAttendance[r.id]].label : "미체크",
      r.vehicle,
    ]);
  });

  const csv = rows.map(row =>
    row.map(cell => {
      const s = String(cell === undefined || cell === null ? "" : cell);
      return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
    }).join(",")
  ).join("\r\n");

  // BOM 추가해서 엑셀에서 한글 안 깨지게
  const blob = new Blob(["\uFEFF" + csv], { type: "text/csv;charset=utf-8;" });
  downloadBlob(blob, `출석현황_${dateKey}.csv`);
}

function exportToExcel(){
  try {
    const dateKey = S.selectedDate;
    const dateLabel = formatDateLabel(dateKey);
    const todayAttendance = S.attendance[dateKey] || {};
    const todayMeals = S.meals[dateKey] || {};
    const counts = computeCounts();

    const absentNames = S.residents.filter(r => todayAttendance[r.id] === "absent").map(r => r.name);
    const expectedNames = S.residents.filter(r => todayAttendance[r.id] === "expected").map(r => r.name);

    exportAsCSV(dateKey, dateLabel, todayAttendance, todayMeals, counts, absentNames, expectedNames);
  } catch (e) {
    console.error(e);
    alert("내보내기에 실패했어요: " + (e && e.message ? e.message : e));
  }
}

/* ---------- Render helpers ---------- */
function esc(str){
  return String(str).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}

function renderHeader(){
  const counts = computeCounts();
  const isToday = S.selectedDate === todayKey();
  return `
    <div class="header">
      <div class="header-nav">
        <button class="nav-btn" onclick="shiftDate(-1)">‹</button>
        <div class="date-label" onclick="${isToday ? "" : "goToday()"}">
          <span>☀️</span>
          <span>${formatDateLabel(S.selectedDate)}</span>
          ${!isToday ? `<span class="today-badge">오늘로</span>` : ""}
        </div>
        <button class="nav-btn" onclick="shiftDate(1)">›</button>
      </div>
      <div class="center-name">서구케어재가노인주간보호센터</div>
      <div class="stats-row">
        <div><div class="stat-num">${counts.present}</div><div class="stat-label">출석</div></div>
        <div><div class="stat-num">${counts.absent}</div><div class="stat-label">결석</div></div>
        <div><div class="stat-num">${counts.expected}</div><div class="stat-label">등원예정</div></div>
      </div>
    </div>
  `;
}

function renderTabs(){
  const tabs = [
    { key: "slides", label: "현황판", icon: "📊" },
    { key: "floor2", label: "2층", icon: "✓" },
    { key: "floor3", label: "3층", icon: "✓" },
    { key: "vehicle", label: "하원관리", icon: "🚌" },
    { key: "roster", label: "명단관리", icon: "👥" },
  ];
  return `
    <div class="tabs">
      ${tabs.map(t => `
        <button class="tab-btn ${S.tab === t.key ? "active" : ""}" onclick="setTab('${t.key}')">
          <span class="tab-icon">${t.icon}</span>
          <span>${t.label}</span>
        </button>
      `).join("")}
    </div>
  `;
}

function renderMealCounter(floor){
  const todayMeals = S.meals[S.selectedDate] || {};
  const c = todayMeals[floor] || 0;
  return `
    <div class="meal-counter">
      <div class="meal-left"><span>🍽️</span><span>${floor} 조식</span></div>
      <div class="meal-right">
        <button class="meal-btn" onclick="setMealCount('${floor}', ${Math.max(0,c-1)})">−</button>
        <span class="meal-count">${c}</span>
        <button class="meal-btn" onclick="setMealCount('${floor}', ${c+1})">+</button>
      </div>
    </div>
  `;
}

function renderEmptyState(){
  return `
    <div class="empty-box">
      <div class="big-icon">👥</div>
      <div class="title">등록된 어르신이 없어요</div>
      <div style="font-size:13px;margin-bottom:16px;">명단관리 탭에서 먼저 등록해주세요</div>
      <button class="primary-btn" onclick="setTab('roster'); toggleAddForm();">어르신 등록하기</button>
    </div>
  `;
}

function renderFloorTab(floor){
  const list = sortByName(S.residents.filter(r => r.floor === floor));
  const todayAttendance = S.attendance[S.selectedDate] || {};
  let rows;
  if (list.length === 0) {
    rows = `<div class="floor-empty">${floor}에 등록된 어르신이 없어요</div>`;
  } else {
    rows = list.map(r => {
      const current = todayAttendance[r.id];
      const borderColor = current ? STATUS[current].color : "#E4DDCF";
      const bg = current ? STATUS[current].bg : "#fff";
      const schedule = r.schedule || [];
      const isCustom = schedule.length > 0;
      const scheduledToday = isScheduledDay(r, S.selectedDate);
      const btns = Object.entries(STATUS).map(([key, s]) => {
        const active = current === key;
        return `
          <button class="status-btn" style="border-color:${active ? s.color : "#D9D2C3"};background:${active ? s.color : "#fff"};color:${active ? "#fff" : "#5A5248"};" onclick="setStatus('${r.id}','${key}')">
            <span>${s.icon}</span><span>${s.label}</span>
          </button>
        `;
      }).join("");
      const scheduleBadge = isCustom ? `
        <div style="font-size:10px;font-weight:700;color:${scheduledToday ? "#B0995B" : "#B5AFA3"};margin-top:1px;">
          ${schedule.join("·")}
        </div>
      ` : "";
      return `
        <div class="resident-row" style="border-color:${borderColor};background:${bg};${isCustom && !scheduledToday ? "opacity:0.6;" : ""}">
          <div style="flex-shrink:0;min-width:52px;">
            <div class="resident-name" style="margin:0;">${esc(r.name)}</div>
            ${scheduleBadge}
          </div>
          <div class="status-group">${btns}</div>
        </div>
      `;
    }).join("");
  }
  return `
    ${renderMealCounter(floor)}
    <div class="floor-title">${floor} · ${list.length}명</div>
    ${rows}
  `;
}

function renderVehicleTab(){
  const todayAttendance = S.attendance[S.selectedDate] || {};
  const present = S.residents.filter(r => todayAttendance[r.id] === "present");
  if (present.length === 0) {
    return `
      <div class="empty-box">
        <div class="big-icon">🚌</div>
        <div style="font-size:13px;">해당 날짜에 '출석'으로 표시된 분이 없어요</div>
      </div>
    `;
  }
  return VEHICLES.map(v => {
    const c = VEHICLE_COLORS[v];
    const list = present.filter(r => r.vehicle === v);
    const chips = list.map(r => `
      <div class="vehicle-chip">
        <span style="font-size:13px;font-weight:700;">${esc(r.name)}</span>
        <select onchange="setVehicle('${r.id}', this.value)">
          ${VEHICLES.map(vv => `<option value="${vv}" ${vv===r.vehicle?"selected":""}>${vv}</option>`).join("")}
        </select>
      </div>
    `).join("");
    return `
      <div class="vehicle-card" style="background:${c.bg};border:1.5px solid ${c.border};">
        <div class="vehicle-head" style="color:${c.text};"><span>🚌</span><span>${v}</span><span style="font-size:12px;opacity:0.7;">${list.length}명</span></div>
        ${list.length === 0 ? `<div style="font-size:12px;color:${c.text};opacity:0.6;">배정된 인원 없음</div>` : `<div class="vehicle-chips">${chips}</div>`}
      </div>
    `;
  }).join("");
}

function renderRosterTab(){
  const addForm = S.showAdd ? `
    <div class="add-form">
      <input id="newNameInput" placeholder="이름" value="${esc(S.newName)}" oninput="updateNewName(this.value)" />
      <div class="add-form-row">
        <select onchange="updateNewFloor(this.value)">
          ${FLOORS.map(f => `<option value="${f}" ${f===S.newFloor?"selected":""}>${f}</option>`).join("")}
        </select>
        <select onchange="updateNewVehicle(this.value)">
          ${VEHICLES.map(v => `<option value="${v}" ${v===S.newVehicle?"selected":""}>${v}</option>`).join("")}
        </select>
      </div>
      <button class="primary-btn" style="padding:11px;" onclick="addResident()">등록하기</button>
    </div>
  ` : "";

  const sortedResidents = [...S.residents].sort((a, b) => {
    if (a.floor !== b.floor) return a.floor.localeCompare(b.floor, "ko");
    return a.name.localeCompare(b.name, "ko");
  });
  const items = sortedResidents.map(r => {
    const schedule = r.schedule || [];
    const isDaily = schedule.length === 0;
    const dayChips = WEEKDAYS.map(day => {
      const active = schedule.includes(day);
      return `
        <button style="width:30px;height:28px;border-radius:8px;border:1.5px solid ${active ? "#B0995B" : "#D9D2C3"};background:${active ? "#B0995B" : "#fff"};color:${active ? "#fff" : "#8A8378"};font-size:12px;font-weight:700;" onclick="toggleScheduleDay('${r.id}','${day}')">${day}</button>
      `;
    }).join("");
    return `
      <div class="roster-item" style="flex-direction:column;align-items:stretch;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
          <div>
            <div class="name">${esc(r.name)}</div>
            <div class="meta" style="display:flex;align-items:center;gap:6px;">
              <span>${r.floor}</span>
              <span>·</span>
              <select onchange="setVehicle('${r.id}', this.value)" style="border:1px solid #D9D2C3;border-radius:6px;padding:2px 6px;font-size:12px;font-weight:700;color:#5A5248;background:#fff;">
                ${VEHICLES.map(v => `<option value="${v}" ${v===r.vehicle?"selected":""}>${v}</option>`).join("")}
              </select>
            </div>
          </div>
          <button class="del-btn" onclick="removeResident('${r.id}')">🗑️</button>
        </div>
        <div style="display:flex;gap:4px;flex-wrap:wrap;">
          <button style="padding:5px 10px;border-radius:8px;border:1.5px solid ${isDaily ? "#3F5245" : "#D9D2C3"};background:${isDaily ? "#3F5245" : "#fff"};color:${isDaily ? "#fff" : "#8A8378"};font-size:11px;font-weight:700;" onclick="clearSchedule('${r.id}')">매일</button>
          ${dayChips}
        </div>
      </div>
    `;
  }).join("");

  return `
    <button class="roster-add-btn" onclick="toggleAddForm()"><span>➕</span><span>어르신 등록</span></button>
    ${addForm}
    ${items}
  `;
}

function renderSlides(){
  const counts = computeCounts();
  const todayMeals = S.meals[S.selectedDate] || {};
  const todayAttendance = S.attendance[S.selectedDate] || {};
  const total = S.residents.length;

  let inner;
  if (S.page === 0) {
    inner = `
      <div class="slide-date">${formatDateLabel(S.selectedDate)}</div>
      <div class="slide-title">오늘 총인원 결과</div>
      <div class="total-circle"><div class="num">${total}</div><div class="lbl">전체 인원</div></div>
      ${["present","absent","expected"].map(k => `
        <div class="status-summary-row" style="background:${STATUS[k].bg};border-color:${STATUS[k].color};">
          <span style="font-size:16px;font-weight:700;color:${STATUS[k].color};">${STATUS[k].label}</span>
          <span style="font-size:22px;font-weight:800;color:${STATUS[k].color};">${counts[k]}명</span>
        </div>
      `).join("")}
      <div class="meal-summary-row">
        ${FLOORS.map(f => `
          <div class="meal-summary-box">
            <div style="font-size:13px;font-weight:700;color:#7A6238;">${f} 조식</div>
            <div style="font-size:22px;font-weight:800;color:#7A6238;margin-top:4px;">${todayMeals[f]||0}개</div>
          </div>
        `).join("")}
      </div>
    `;
  } else {
    const floor = FLOORS[S.page - 1];
    const list = sortByName(S.residents.filter(r => r.floor === floor));
    inner = `
      <div class="slide-date">${floor} 어르신 현황</div>
      <div class="slide-title">총 ${list.length}명</div>
      ${list.length === 0 ? `<div style="text-align:center;color:#8A8378;padding:30px;font-size:13px;">등록된 어르신이 없어요</div>` :
        list.map(r => {
          const s = todayAttendance[r.id];
          return `
            <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-radius:12px;background:${s?STATUS[s].bg:"#F5F3EE"};margin-bottom:8px;">
              <span style="font-size:16px;font-weight:700;">${esc(r.name)}</span>
              <span style="font-size:12px;font-weight:700;color:${s?STATUS[s].color:"#B5AFA3"};">${s?STATUS[s].label:"미체크"}</span>
            </div>
          `;
        }).join("")
      }
    `;
  }

  return `
    <div class="slide-card">${inner}</div>
    <div class="slide-nav">
      <button class="slide-nav-btn" ${S.page===0?"disabled":""} onclick="gotoPage(${S.page-1})">‹ 이전</button>
      <div class="dots">
        ${[0,1,2].map(i => `<div class="dot ${i===S.page?"active":""}" onclick="gotoPage(${i})"></div>`).join("")}
      </div>
      <button class="slide-nav-btn" ${S.page===2?"disabled":""} onclick="gotoPage(${S.page+1})">다음 ›</button>
    </div>
    <button class="export-btn" onclick="exportToExcel()"><span>⬇️</span><span>파일로 내보내기 (엑셀)</span></button>
  `;
}

/* ---------- Main render ---------- */
function render(){
  const app = document.getElementById("app");
  if (!S.loaded) {
    app.innerHTML = renderHeader() + renderTabs() + `<div class="content"><div class="empty-box">불러오는 중...</div></div>`;
    return;
  }

  const isToday = S.selectedDate === todayKey();
  let body = "";
  if (S.residents.length === 0 && S.tab !== "roster") {
    body = renderEmptyState();
  } else if (S.tab === "slides") {
    body = renderSlides();
  } else if (S.tab === "floor2") {
    body = renderFloorTab("2층");
  } else if (S.tab === "floor3") {
    body = renderFloorTab("3층");
  } else if (S.tab === "vehicle") {
    body = renderVehicleTab();
  } else if (S.tab === "roster") {
    body = renderRosterTab();
  }

  const banner = (!isToday && S.tab !== "roster") ? `<div class="date-banner">${formatDateLabel(S.selectedDate)} 기록을 보고 있어요</div>` : "";

  app.innerHTML = renderHeader() + renderTabs() + `<div class="content">${banner}${body}</div>`;

  const nameInput = document.getElementById("newNameInput");
  if (nameInput) {
    nameInput.focus();
    const val = nameInput.value;
    nameInput.value = "";
    nameInput.value = val;
  }
}

loadAll();
