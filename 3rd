let saveTimer = null;
let debounceTimers = {};

function showSaveState(state){
  const el = document.getElementById("saveIndicator");
  el.classList.remove("error");
  if (state === "saving") { el.textContent = "저장 중..."; el.classList.add("show"); }
  else if (state === "saved") { el.textContent = "저장됨 ✓"; el.classList.add("show"); clearTimeout(saveTimer); saveTimer = setTimeout(()=>el.classList.remove("show"), 1200); }
  else if (state === "error") { el.textContent = "저장 실패 (다시 시도해주세요)"; el.classList.add("error","show"); clearTimeout(saveTimer); saveTimer = setTimeout(()=>el.classList.remove("show"), 2500); }
}

function persist(key, value){
  showSaveState("saving");
  try {
    lsSet(key, JSON.stringify(value));
    showSaveState("saved");
  } catch(e) {
    showSaveState("error");
  }
}
function debouncedPersist(key, value){
  if (debounceTimers[key]) clearTimeout(debounceTimers[key]);
  debounceTimers[key] = setTimeout(()=>persist(key, value), 350);
}

